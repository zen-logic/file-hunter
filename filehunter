#!/usr/bin/env bash
set -euo pipefail

# ── Resolve install directory (where this script lives) ──────────────

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

VENV_DIR="$SCRIPT_DIR/venv"
DATA_DIR="$SCRIPT_DIR/data"
CONFIG_FILE="$SCRIPT_DIR/config.json"
AGENT_CONFIG="$DATA_DIR/agent_config.json"

# ── Helpers ──────────────────────────────────────────────────────────

info()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33mWarning:\033[0m %s\n' "$*"; }
error() { printf '\033[1;31mError:\033[0m %s\n' "$*" >&2; exit 1; }

prompt() {
    local label="$1" default="$2" var="$3"
    printf '  %s [%s]: ' "$label" "$default"
    read -r input
    eval "$var=\"\${input:-$default}\""
}

# ── Find Python 3.10+ ───────────────────────────────────────────────

find_python() {
    for cmd in python3 python; do
        if command -v "$cmd" >/dev/null 2>&1; then
            version=$("$cmd" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null) || continue
            major=${version%%.*}
            minor=${version#*.}
            if [ "$major" -eq 3 ] && [ "$minor" -ge 10 ]; then
                echo "$cmd"
                return
            fi
        fi
    done
    return 1
}

PYTHON=$(find_python) || error "Python 3.10+ is required but not found."

# ── Install a specific version ───────────────────────────────────────

REPO="zen-logic/file-hunter"
CURRENT=$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')

install_version() {
    local TAG="$1"
    local VERSION="${TAG#v}"

    local ARCHIVE="filehunter-${VERSION}.tar.gz"
    local URL="https://github.com/${REPO}/releases/download/${TAG}/${ARCHIVE}"

    curl -fSL "$URL" -o "/tmp/${ARCHIVE}" || error "Download failed. Check the version exists: ${TAG}"

    local TMPDIR
    TMPDIR=$(mktemp -d)
    tar xzf "/tmp/${ARCHIVE}" -C "$TMPDIR"
    rm -f "/tmp/${ARCHIVE}"

    local EXTRACTED="$TMPDIR/filehunter-${VERSION}"
    if [ ! -d "$EXTRACTED" ]; then
        rm -rf "$TMPDIR"
        error "Unexpected archive structure."
    fi

    for dir in file_hunter file_hunter_core file_hunter_agent static; do
        rm -rf "${SCRIPT_DIR:?}/$dir"
    done

    for item in "$EXTRACTED"/*; do
        local name
        name=$(basename "$item")
        case "$name" in
            data|config.json|venv) continue ;;
        esac
        cp -R "$item" "$SCRIPT_DIR/"
    done

    rm -rf "$TMPDIR"
    chmod +x "$SCRIPT_DIR/filehunter"
}

# ── Self-update ──────────────────────────────────────────────────────

if [ "${1:-}" = "update" ]; then
    FORCE=false
    [ "${2:-}" = "--force" ] && FORCE=true

    info "Checking for updates (current: v${CURRENT})..."
    LATEST_TAG=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
        | "$PYTHON" -c "import sys,json; print(json.load(sys.stdin).get('tag_name',''))" 2>/dev/null)

    if [ -z "$LATEST_TAG" ]; then
        error "Could not check for updates."
    fi

    LATEST="${LATEST_TAG#v}"

    if [ "$CURRENT" = "$LATEST" ] && [ "$FORCE" = false ]; then
        info "Already up to date (v${CURRENT})."
        exit 0
    fi

    if [ "$CURRENT" = "$LATEST" ]; then
        info "Reinstalling v${CURRENT}..."
    else
        info "Updating v${CURRENT} → v${LATEST}..."
    fi

    install_version "$LATEST_TAG"
    info "Updated to v${LATEST}. Restart with: ./filehunter"
    exit 0
fi

# ── Install specific version ────────────────────────────────────────

if [ "${1:-}" = "version" ]; then
    if [ -z "${2:-}" ]; then
        echo "v${CURRENT}"
        exit 0
    fi

    TARGET_TAG="${2}"
    # Accept with or without v prefix
    case "$TARGET_TAG" in
        v*) ;;
        *)  TARGET_TAG="v${TARGET_TAG}" ;;
    esac
    TARGET_VERSION="${TARGET_TAG#v}"

    if [ "$CURRENT" = "$TARGET_VERSION" ]; then
        info "Already on v${CURRENT}. Use './filehunter update --force' to reinstall."
        exit 0
    fi

    info "Switching v${CURRENT} → v${TARGET_VERSION}..."
    install_version "$TARGET_TAG"
    info "Installed v${TARGET_VERSION}. Restart with: ./filehunter"
    exit 0
fi

# ── First-run setup ─────────────────────────────────────────────────

if [ ! -f "$CONFIG_FILE" ]; then
    mkdir -p "$DATA_DIR"

    echo ""
    echo "  File Hunter — first run setup"
    echo ""

    prompt "Server host" "127.0.0.1" FH_HOST
    prompt "Server port" "8000" FH_PORT
    prompt "Agent port"  "8001" FH_AGENT_PORT

    echo ""

    cat > "$CONFIG_FILE" <<EOF
{
    "host": "$FH_HOST",
    "port": $FH_PORT,
    "agent_port": $FH_AGENT_PORT,
    "database": "data/file_hunter.db"
}
EOF

    info "Saved to config.json"
fi

# ── Virtual environment ─────────────────────────────────────────────

if [ ! -d "$VENV_DIR" ]; then
    info "Creating virtual environment..."
    "$PYTHON" -m venv "$VENV_DIR"
fi

VENV_PYTHON="$VENV_DIR/bin/python"

# Install/update deps if needed (check stamp vs requirements.txt)
STAMP="$VENV_DIR/.deps-installed"
if [ ! -f "$STAMP" ] || [ "$SCRIPT_DIR/requirements.txt" -nt "$STAMP" ]; then
    info "Installing dependencies..."
    "$VENV_PYTHON" -m pip install --quiet --upgrade pip
    "$VENV_PYTHON" -m pip install --quiet -r "$SCRIPT_DIR/requirements.txt"
    touch "$STAMP"
fi

# If agent is a sibling repo (source install), install it into the venv
AGENT_SIBLING="$SCRIPT_DIR/../file-hunter-agent"
if [ -d "$AGENT_SIBLING/file_hunter_agent" ] && ! "$VENV_PYTHON" -c "import file_hunter_agent" 2>/dev/null; then
    info "Installing agent from sibling repo..."
    "$VENV_PYTHON" -m pip install --quiet -e "$AGENT_SIBLING"
fi

# Install pro extension if present
if [ -d "$SCRIPT_DIR/file-hunter-pro/file_hunter_pro" ]; then
    if ! "$VENV_PYTHON" -c "import file_hunter_pro" 2>/dev/null; then
        info "Installing Pro extension..."
        "$VENV_PYTHON" -m pip install --quiet -e "$SCRIPT_DIR/file-hunter-pro"
    fi
fi

# ── Pre-flight (DB init + local agent config) ───────────────────────

"$VENV_PYTHON" -m file_hunter.preflight || error "Pre-flight setup failed."

# ── Read config for ports ───────────────────────────────────────────

FH_HOST=$("$VENV_PYTHON" -c "import json; c=json.load(open('config.json')); print(c.get('host','127.0.0.1'))")
FH_PORT=$("$VENV_PYTHON" -c "import json; c=json.load(open('config.json')); print(c.get('port',8000))")
FH_AGENT_PORT=$("$VENV_PYTHON" -c "import json; c=json.load(open('config.json')); print(c.get('agent_port',8001))")

# ── Process management ────────────────────────────────────────────────

AGENT_PID=""
RESTART_CODE=75

cleanup() {
    if [ -n "$AGENT_PID" ] && kill -0 "$AGENT_PID" 2>/dev/null; then
        kill "$AGENT_PID" 2>/dev/null
        wait "$AGENT_PID" 2>/dev/null || true
    fi
}
trap cleanup EXIT INT TERM

# ── Main loop (restarts on exit code 75) ──────────────────────────────

while true; do
    # Start agent (if bundled)
    AGENT_PID=""
    if [ -f "$AGENT_CONFIG" ] && "$VENV_PYTHON" -c "import file_hunter_agent" 2>/dev/null; then
        "$VENV_PYTHON" -m file_hunter_agent \
            --host "$FH_HOST" \
            --port "$FH_AGENT_PORT" \
            --server "http://${FH_HOST}:${FH_PORT}" \
            --config "$AGENT_CONFIG" &
        AGENT_PID=$!
    fi

    set +e
    "$VENV_PYTHON" -m file_hunter --host "$FH_HOST" --port "$FH_PORT"
    SERVER_EXIT=$?
    set -e

    # Always stop the agent before deciding what to do
    cleanup
    AGENT_PID=""

    if [ "$SERVER_EXIT" -eq "$RESTART_CODE" ]; then
        info "Restarting..."
        continue
    fi

    exit "$SERVER_EXIT"
done
